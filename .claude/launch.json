{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@violet/ui", "storybook:ci"],
      "port": 6006
    },
    {
      "name": "tokens-showcase",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "packages/tokens", "-l", "4321"],
      "port": 4321
    },
    {
      "name": "reference-site",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@violet/reference-site", "exec", "next", "dev", "--port", "3100"],
      "port": 3100
    },
    {
      "name": "order-app",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@violet/order-app", "dev"],
      "port": 5173
    }
  ]
}
