{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "Violet Design Tokens — W3C DTCG format. Import into Figma via the Tokens Studio plugin. Primitive sets feed the semantic 'light' and 'dark' theme sets.",
  "primitive": {
    "color": {
      "violet": {
        "50":  { "$type": "color", "$value": "#F5F3FF" },
        "100": { "$type": "color", "$value": "#EDE9FE" },
        "200": { "$type": "color", "$value": "#DDD6FE" },
        "300": { "$type": "color", "$value": "#C4B5FD" },
        "400": { "$type": "color", "$value": "#A855F7" },
        "500": { "$type": "color", "$value": "#8B5CF6" },
        "600": { "$type": "color", "$value": "#7C3AED", "$description": "Brand primary" },
        "700": { "$type": "color", "$value": "#6D28D9" },
        "800": { "$type": "color", "$value": "#5B21B6" },
        "900": { "$type": "color", "$value": "#4C1D95" },
        "950": { "$type": "color", "$value": "#2E1065" }
      },
      "gold": {
        "50":  { "$type": "color", "$value": "#FBF7EF" },
        "100": { "$type": "color", "$value": "#F4E9D2" },
        "200": { "$type": "color", "$value": "#E8D2A6" },
        "300": { "$type": "color", "$value": "#D9B978" },
        "400": { "$type": "color", "$value": "#C9A86A", "$description": "Champagne accent" },
        "500": { "$type": "color", "$value": "#B8946A" },
        "600": { "$type": "color", "$value": "#9A7849" }
      },
      "ink": {
        "50":  { "$type": "color", "$value": "#F8F7FF" },
        "100": { "$type": "color", "$value": "#F3F1FA" },
        "150": { "$type": "color", "$value": "#EEEBF6" },
        "200": { "$type": "color", "$value": "#E5E2EE" },
        "300": { "$type": "color", "$value": "#C7C3D4" },
        "400": { "$type": "color", "$value": "#9C97AC" },
        "500": { "$type": "color", "$value": "#6B7280" },
        "600": { "$type": "color", "$value": "#4B4263" },
        "700": { "$type": "color", "$value": "#2E2348" },
        "800": { "$type": "color", "$value": "#231940" },
        "900": { "$type": "color", "$value": "#18122B" },
        "950": { "$type": "color", "$value": "#0D0A1E" }
      },
      "green": { "50": { "$type": "color", "$value": "#ECFDF5" }, "500": { "$type": "color", "$value": "#10B981" }, "600": { "$type": "color", "$value": "#059669" }, "700": { "$type": "color", "$value": "#047857" } },
      "amber": { "50": { "$type": "color", "$value": "#FFF7ED" }, "500": { "$type": "color", "$value": "#F59E0B" }, "600": { "$type": "color", "$value": "#D97706" }, "700": { "$type": "color", "$value": "#B45309" } },
      "red":   { "50": { "$type": "color", "$value": "#FEF2F2" }, "500": { "$type": "color", "$value": "#EF4444" }, "600": { "$type": "color", "$value": "#DC2626" }, "700": { "$type": "color", "$value": "#B91C1C" } },
      "blue":  { "50": { "$type": "color", "$value": "#EFF6FF" }, "500": { "$type": "color", "$value": "#3B82F6" }, "600": { "$type": "color", "$value": "#2563EB" }, "700": { "$type": "color", "$value": "#1D4ED8" } },
      "white": { "$type": "color", "$value": "#FFFFFF" },
      "black": { "$type": "color", "$value": "#000000" }
    },
    "fontFamily": {
      "display": { "$type": "fontFamily", "$value": ["Cormorant Garamond", "Playfair Display", "Georgia", "serif"] },
      "sans":    { "$type": "fontFamily", "$value": ["Inter", "system-ui", "sans-serif"] },
      "arabic":  { "$type": "fontFamily", "$value": ["IBM Plex Sans Arabic", "Noto Sans Arabic", "Tahoma", "sans-serif"] },
      "persian": { "$type": "fontFamily", "$value": ["Vazirmatn", "Vazir", "Tahoma", "sans-serif"] },
      "mono":    { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
    },
    "fontSize": {
      "2xs":  { "$type": "dimension", "$value": "11px" },
      "xs":   { "$type": "dimension", "$value": "12px" },
      "sm":   { "$type": "dimension", "$value": "14px" },
      "base": { "$type": "dimension", "$value": "16px" },
      "lg":   { "$type": "dimension", "$value": "18px" },
      "xl":   { "$type": "dimension", "$value": "22px" },
      "2xl":  { "$type": "dimension", "$value": "28px" },
      "3xl":  { "$type": "dimension", "$value": "36px" },
      "4xl":  { "$type": "dimension", "$value": "48px" },
      "5xl":  { "$type": "dimension", "$value": "64px" },
      "6xl":  { "$type": "dimension", "$value": "84px" }
    },
    "fontWeight": {
      "light": { "$type": "fontWeight", "$value": 300 },
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "lineHeight": {
      "none": { "$type": "number", "$value": 1 },
      "tight": { "$type": "number", "$value": 1.15 },
      "snug": { "$type": "number", "$value": 1.3 },
      "normal": { "$type": "number", "$value": 1.55 },
      "relaxed": { "$type": "number", "$value": 1.75 }
    },
    "letterSpacing": {
      "tighter": { "$type": "dimension", "$value": "-0.02em" },
      "tight": { "$type": "dimension", "$value": "-0.01em" },
      "normal": { "$type": "dimension", "$value": "0em" },
      "wide": { "$type": "dimension", "$value": "0.04em" },
      "wider": { "$type": "dimension", "$value": "0.12em" }
    },
    "space": {
      "0": { "$type": "dimension", "$value": "0px" },
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "20px" },
      "6": { "$type": "dimension", "$value": "24px" },
      "8": { "$type": "dimension", "$value": "32px" },
      "10": { "$type": "dimension", "$value": "40px" },
      "12": { "$type": "dimension", "$value": "48px" },
      "16": { "$type": "dimension", "$value": "64px" },
      "20": { "$type": "dimension", "$value": "80px" },
      "24": { "$type": "dimension", "$value": "96px" },
      "32": { "$type": "dimension", "$value": "128px" }
    },
    "radius": {
      "none": { "$type": "dimension", "$value": "0px" },
      "sm": { "$type": "dimension", "$value": "6px" },
      "md": { "$type": "dimension", "$value": "10px" },
      "lg": { "$type": "dimension", "$value": "14px" },
      "xl": { "$type": "dimension", "$value": "20px" },
      "2xl": { "$type": "dimension", "$value": "28px" },
      "pill": { "$type": "dimension", "$value": "9999px" }
    },
    "shadow": {
      "xs":  { "$type": "shadow", "$value": { "color": "#7C3AED0F", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" } },
      "sm":  { "$type": "shadow", "$value": { "color": "#7C3AED14", "offsetX": "0px", "offsetY": "2px", "blur": "8px", "spread": "0px" } },
      "md":  { "$type": "shadow", "$value": { "color": "#7C3AED1A", "offsetX": "0px", "offsetY": "2px", "blur": "16px", "spread": "0px" } },
      "lg":  { "$type": "shadow", "$value": { "color": "#7C3AED24", "offsetX": "0px", "offsetY": "8px", "blur": "32px", "spread": "0px" } },
      "xl":  { "$type": "shadow", "$value": { "color": "#7C3AED33", "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px" } },
      "2xl": { "$type": "shadow", "$value": { "color": "#7C3AED47", "offsetX": "0px", "offsetY": "24px", "blur": "72px", "spread": "0px" } }
    },
    "duration": {
      "instant": { "$type": "duration", "$value": "80ms" },
      "fast": { "$type": "duration", "$value": "150ms" },
      "base": { "$type": "duration", "$value": "240ms" },
      "slow": { "$type": "duration", "$value": "400ms" },
      "slower": { "$type": "duration", "$value": "700ms" }
    }
  },
  "semantic": {
    "$description": "Light theme. Mirror this set as a 'dark' theme in Tokens Studio using the dark values documented in tokens.css.",
    "color": {
      "bg":            { "$type": "color", "$value": "{primitive.color.ink.50}" },
      "surface":       { "$type": "color", "$value": "{primitive.color.white}" },
      "surface-sunken":{ "$type": "color", "$value": "{primitive.color.ink.100}" },
      "surface-raised":{ "$type": "color", "$value": "{primitive.color.white}" },
      "surface-inverse":{ "$type": "color", "$value": "{primitive.color.ink.950}" },
      "text":          { "$type": "color", "$value": "{primitive.color.ink.900}" },
      "text-strong":   { "$type": "color", "$value": "{primitive.color.ink.950}" },
      "text-muted":    { "$type": "color", "$value": "{primitive.color.ink.500}" },
      "text-subtle":   { "$type": "color", "$value": "{primitive.color.ink.400}" },
      "text-on-brand": { "$type": "color", "$value": "{primitive.color.white}" },
      "link":          { "$type": "color", "$value": "{primitive.color.violet.700}" },
      "border":        { "$type": "color", "$value": "{primitive.color.ink.200}" },
      "border-strong": { "$type": "color", "$value": "{primitive.color.ink.300}" },
      "divider":       { "$type": "color", "$value": "{primitive.color.ink.150}" },
      "primary":       { "$type": "color", "$value": "{primitive.color.violet.600}" },
      "primary-hover": { "$type": "color", "$value": "{primitive.color.violet.700}" },
      "primary-active":{ "$type": "color", "$value": "{primitive.color.violet.800}" },
      "primary-subtle":{ "$type": "color", "$value": "{primitive.color.violet.50}" },
      "on-primary":    { "$type": "color", "$value": "{primitive.color.white}" },
      "accent":        { "$type": "color", "$value": "{primitive.color.gold.400}" },
      "accent-strong": { "$type": "color", "$value": "{primitive.color.gold.600}" },
      "on-accent":     { "$type": "color", "$value": "{primitive.color.ink.950}" },
      "focus-ring":    { "$type": "color", "$value": "{primitive.color.violet.600}" },
      "success":       { "$type": "color", "$value": "{primitive.color.green.600}" },
      "warning":       { "$type": "color", "$value": "{primitive.color.amber.600}" },
      "danger":        { "$type": "color", "$value": "{primitive.color.red.600}" },
      "info":          { "$type": "color", "$value": "{primitive.color.blue.600}" },
      "status-submitted": { "$type": "color", "$value": "{primitive.color.ink.500}" },
      "status-reviewing": { "$type": "color", "$value": "{primitive.color.blue.600}" },
      "status-approved":  { "$type": "color", "$value": "{primitive.color.violet.600}" },
      "status-shipped":   { "$type": "color", "$value": "{primitive.color.amber.600}" },
      "status-completed": { "$type": "color", "$value": "{primitive.color.green.600}" },
      "status-rejected":  { "$type": "color", "$value": "{primitive.color.red.600}" }
    }
  }
}
