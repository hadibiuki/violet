{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "chrome.jsx",
              "components/brand/**",
              "components/commerce/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/marketing/**",
              "components/navigation/**",
              "presentation/**",
              "site/**",
              "ui_kits/b2b-app/**",
              "ui_kits/reference-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IRANYekanX|Cormorant Garamond|Cinzel|Pinyon Script|Inter|JetBrains Mono|Vazirmatn|Cairo|Amiri))/i]",
        "message": "Font not provided by the design system. Available: IRANYekanX, Cormorant Garamond, Cinzel, Pinyon Script, Inter, JetBrains Mono, Vazirmatn, Cairo, Amiri."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:new|limited|neutral|soldout)$/]",
        "message": "<Badge> variant must be one of 'new' | 'limited' | 'neutral' | 'soldout'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|size|framed|tagline|key|ref|className|style|children)$/]",
        "message": "<BrandMark> doesn't accept that prop. Declared props: variant, tone, size, framed, tagline."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lockup|horizontal|monogram|wordmark)$/]",
        "message": "<BrandMark> variant must be one of 'lockup' | 'horizontal' | 'monogram' | 'wordmark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|ink|onDark)$/]",
        "message": "<BrandMark> tone must be one of 'light' | 'ink' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<BrandMark> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreadcrumbItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<BreadcrumbItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|leadingIcon|trailingIcon|loading|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, leadingIcon, trailingIcon, loading."
