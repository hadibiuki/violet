{
  "name": "@violet/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Violet shared component library — accessible primitives (headless/Radix) styled with the token system (docs/trade-offs.md TD-12).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
